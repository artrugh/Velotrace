{
  "name": "web-portal",
  "projectType": "application",
  "sourceRoot": "apps/web-portal",
  "targets": {
    "build": {
      "command": "npm run build",
      "options": {
        "cwd": "apps/web-portal"
      },
      "outputs": ["{workspaceRoot}/apps/web-portal/dist"]
    },
    "serve": {
      "command": "npm run dev",
      "options": {
        "cwd": "apps/web-portal"
      }
    }
  }
}
