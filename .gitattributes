# Enforce LF for all text files
* text=auto eol=lf

# Force shell scripts to use LF line endings
*.sh text eol=lf

# Handle line endings automatically
*.yaml text eol=lf
*.yml text eol=lf

# Explicitly handle other common text files
Dockerfile* text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf
*.json text eol=lf
*.md text eol=lf
*.ts text eol=lf
*.vue text eol=lf
*.go text eol=lf
