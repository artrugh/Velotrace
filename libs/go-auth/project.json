{
  "name": "go-auth",
  "projectType": "library",
  "sourceRoot": "libs/go-auth",
  "implicitDependencies": ["go-logger"],
  "targets": {
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "go test ./... -v",
        "cwd": "libs/go-auth"
      }
    },
    "local-test": {
      "executor": "nx:run-commands",
      "dependsOn": ["test"],
      "options": {
        "command": "echo 'Running test target'",
        "cwd": "libs/go-auth"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "golangci-lint run ./... -v --config=../../.golangci.yml",
        "cwd": "libs/go-auth"
      }
    }
  }
}
