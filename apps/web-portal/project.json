{
  "name": "web-portal",
  "projectType": "application",
  "sourceRoot": "apps/web-portal",
  "targets": {
    "build": {
      "command": "npx nuxt build",
      "options": {
        "cwd": "apps/web-portal"
      },
      "outputs": ["{workspaceRoot}/apps/web-portal/.output"]
    },
    "serve": {
      "command": "npx nuxt dev",
      "options": {
        "cwd": "apps/web-portal"
      }
    },
    "test": {
      "command": "npx vitest",
      "options": {
        "cwd": "apps/web-portal"
      }
    },
    "generate:contracts": {
      "command": "sh ./scripts/sync-api.sh",
      "options": {
        "cwd": "apps/web-portal"
      }
    },
    "lint": {
      "command": "npx prettier --check . --log-level debug",
      "options": {
        "cwd": "apps/web-portal"
      }
    }
  }
}
